# App topology
NODE_ENV=development
FRONTEND_PORT=3000
BACKEND_PORT=3001
BACKEND_INTERNAL_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_EXPLORER_TX_BASE=https://testnet.arcscan.app/tx

# Local database
DB_MODE=auto
POSTGRES_DB=muse
POSTGRES_USER=muse
POSTGRES_PASSWORD=muse
POSTGRES_PORT=5432
DATABASE_URL=postgresql://muse:muse@localhost:5432/muse

# Hermes
HERMES_URL=http://localhost:8642

# x402 / Arc / Circle
MOCK_X402=true
MOCK_X402_SEED=muse-local-demo
REQUIRE_X402_CHALLENGE=true
MUSE_X402_TIMEOUT_MS=15000
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
USDC_CONTRACT=0x3600000000000000000000000000000000000000
USDC_TOKEN_ADDRESS=0x3600000000000000000000000000000000000000
GATEWAY_API_BASE_URL=https://gateway-api-testnet.circle.com/v1
X402_FACILITATOR_URL=https://x402.org/facilitator
# SECURITY: Circle API key — create at https://console.circle.com
CIRCLE_API_KEY=
# SECURITY: 32-byte hex Entity Secret — Circle NEVER stores this.
# You MUST: (1) store in a vault/secret manager in production,
# (2) create a recovery file via SDK registerEntitySecretCiphertext(),
# (3) rotate periodically via the Circle Console.
# See Circle Wallets docs at https://developers.circle.com
CIRCLE_ENTITY_SECRET=
# Central payer wallet used by the backend x402 client
ORCHESTRATOR_WALLET_ID=
ORCHESTRATOR_WALLET_ADDRESS=
# Pinned wallet-set ID for the per-user orchestrators (Circle Wallets API).
# Optional — when missing, the backend creates a fresh set on first call.
AGENT_WALLET_SET_ID=
# USDC token ID returned by Circle's getTokens() API for Arc Testnet.
# Optional — orchestrator falls back to USDC_CONTRACT (the address) on send.
USDC_TOKEN_ID=
# Self-managed buyer private key — REQUIRED only for headless CI scripts
# (live-hackathon-proof, e2e-storm). The UI flow does NOT use this; each
# connected MetaMask gets its own per-user orchestrator privkey persisted
# in backend/data/orchestrator-wallets.json. Leaks of this key are limited
# to the CI test wallet.
MUSE_BUYER_PRIVATE_KEY=
# Legacy alias for the line above — kept for older verify-* scripts that
# import it directly. Set to the same value as MUSE_BUYER_PRIVATE_KEY.
ORCHESTRATOR_PRIVATE_KEY=
# Bypass the pre-flight orchestrator/balance check in /api/tasks. Reserved
# for headless CI runs where the caller has already verified its own state.
# DO NOT set this in any production-facing deployment — it lets a hostile
# client launch tasks that fail mid-way after burning ~30s of LLM cascades.
MUSE_SKIP_PREFLIGHT=
# Admin token for state-mutating endpoints (/api/wallet/create, /api/registry/seed).
# When unset and NODE_ENV !== production, dev convenience lets unauthed local
# tooling hit those endpoints; in production the backend refuses to serve
# them at all.
MUSE_ADMIN_TOKEN=
# SIWE (Sign-In With Ethereum) for /api/tasks, /api/history, /api/wallet/withdraw.
# Backend middleware is wired; frontend signing is on the roadmap. For the
# hackathon demo set this to `false` — backend will accept requests with a
# warning log line per call. Set to `true` once the frontend signs requests.
MUSE_REQUIRE_SIWE=false
# Fireworks AI fallback for image (and LLM) generation. Comma-separated list
# of API keys (we rotate round-robin). Used when AIMLAPI / fal.ai exhaust.
# Each key gets a 5-min quarantine after a 401/403/429 response so a bad
# key doesn't burn the next request.
FIREWORKS_API_KEYS=
# HTTPS proxy used by the backend for outbound Circle / Arc / Gemini calls.
# Needed only if your egress IP is blocked by a region-locked Circle endpoint.
# Leave empty for unrestricted networks.
HTTPS_PROXY=
HTTP_PROXY=
GLOBAL_AGENT_HTTP_PROXY=
NO_PROXY=localhost,127.0.0.1
GLOBAL_AGENT_NO_PROXY=localhost,127.0.0.1
# Receiver wallets exposed by each paid agent service
STRATEGY_AGENT_WALLET=0xAAA0000000000000000000000000000000000000
FAST_SEARCH_WALLET=0xBBB0000000000000000000000000000000000000
COPY_AGENT_WALLET=0xCCC0000000000000000000000000000000000000
IMAGE_AGENT_WALLET=0xDDD0000000000000000000000000000000000000
STRATEGY_AGENT_URL=http://localhost:3101/execute
FAST_SEARCH_AGENT_URL=http://localhost:3102/execute
COPYWRITER_AGENT_URL=http://localhost:3103/execute
IMAGE_AGENT_URL=http://localhost:3104/execute
MUSE_BATCH_CONCURRENCY=3
MUSE_UNIT_MAX_ATTEMPTS=3
MUSE_DB_WRITE_MAX_ATTEMPTS=3
MUSE_RECOVER_INTERRUPTED_TASKS=true

# External APIs
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nous/hermes-3
BRAVE_API_KEY=
FAL_API_KEY=
FAL_API_URL=

# ============================================================
# AIMLAPI — primary model gateway for every Muse sub-agent.
# One key fans out across many models so each unit uses a
# different LLM (GPT/Claude/Llama/Mistral/Qwen/DeepSeek/flux).
# ============================================================
AIMLAPI_API_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_DEFAULT_CHAT_MODEL=gpt-4o-mini
AIMLAPI_DEFAULT_IMAGE_MODEL=flux/schnell
AIMLAPI_TIMEOUT_MS=20000

# ============================================================
# GEMINI — Hermes orchestrator brain (Deep Think + Function Calling).
# Qualifies the project for the Gemini hackathon track.
# Create a key at https://aistudio.google.com/apikey
# ============================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro-preview
GEMINI_FLASH_MODEL=gemini-3-flash-preview
GEMINI_TIMEOUT_MS=30000

# ============================================================
# FEATHERLESS — specialized OSS model fallback. Qualifies
# the project for the Featherless hackathon track.
# ============================================================
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_DEFAULT_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
FEATHERLESS_TIMEOUT_MS=25000

# Hermes fallback models — used when the local Hermes daemon is unavailable.
HERMES_PLANNER_MODEL=gpt-4o-mini
HERMES_DNA_MODEL=claude-3-5-sonnet-20241022

# Agent LLM/API configuration
HERMES_MODEL=openrouter/nous/hermes-3
AGENT_LLM_TIMEOUT_MS=12000
AGENT_SEARCH_TIMEOUT_MS=10000
AGENT_IMAGE_TIMEOUT_MS=30000
